meta {
  name: find budget
  type: http
  seq: 5
}

post {
  url: http://localhost:3000/users/budget
  body: json
  auth: inherit
}

headers {
  Authorization: {{token}}
}

body:json {
  {
    "email": "nicholausferguson@icloud.com",
    "year": 2026,
    "month": 14
  }
}

assert {
  res.status: eq 200
  res.body.categories: isArray
}

settings {
  encodeUrl: true
  timeout: 0
}
