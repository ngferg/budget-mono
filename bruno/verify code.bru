meta {
  name: verify code
  type: http
  seq: 8
}

post {
  url: http://localhost:3001/verify_code
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "code": "260185"
  }
}

assert {
  res.status: eq 200
  res.body.categories: isArray
}

settings {
  encodeUrl: true
  timeout: 0
}
